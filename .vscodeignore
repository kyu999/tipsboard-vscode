.vscode/**

# Sources and alternate / stale build outputs (runtime uses dist/ only)
src/**
scripts/**
out/**
media/**

# WebView sources / toolchain (Vite output is under dist/media/)
webview/**

# Marketplace README screenshots (README uses raw.githubusercontent.com URLs)
assets/vscode/marketplace/**

# Dev / internal documentation (not needed in the published VSIX)
.github/**
docs/**
docs_wiki/**
DEVELOPMENT.md
DEVELOPMENT_RULE.md
playwright.config.ts

# Local semantic search evaluation (dev-only; can include large caches under eval/.cache/)
eval/**
vitest.semantic-eval.config.mts
vitest.semantic-prepare.config.mts
tsconfig.semantic-eval.json

# Lockfiles (not required at runtime)
package-lock.json

# Artifacts
**/*.vsix
**/*.map
**/*.test.ts
test-results/**
playwright-report/**
.npm-cache-vsce/**
dist/semantic-pack*/

# Repo hygiene (if present)
.gitignore

tsconfig.extension.json
vitest.config.mts
node_modules/**
!dist/extension/node_modules/**
